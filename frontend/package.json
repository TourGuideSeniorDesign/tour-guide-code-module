{
  "name": "autogiro-tour-guide",
  "version": "0.0.1",
  "description": "Autogiro Tour Guide",
  "main": "./out/main/index.js",
  "author": "",
  "homepage": "./",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-forge package",
    "make": "electron-vite build && electron-forge make",
    "typecheck:node": "tsc --project tsconfig.node.json --noEmit",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "biome:check": "biome check .",
    "gen-types": "ros-typescript-generator --config ros-ts-generator-config.json",
    "predev": "npm run gen-types",
    "prebuild": "npm run gen-types"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "roslib": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/roslib": "^1.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron": "^28.2.0",
    "electron-vite": "^2.0.0",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ros-typescript-generator": "^1.9.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
